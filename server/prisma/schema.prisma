generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  customer
  staff
  admin
  repair_tech
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ItemType {
  pass_fail
  yes_no
  number
  text
  photo
}

enum PaymentStatus {
  pending
  paid
  refunded
  failed
}

enum BookingStatus {
  pending
  confirmed
  assigned
  in_progress
  completed
  cancelled
}

enum AssignmentStatus {
  pending
  in_progress
  completed
  cancelled
}

enum RepairStatus {
  pending
  approved
  declined
  completed
}

enum WorkOrderStatus {
  pending
  scheduled
  in_progress
  completed
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  name      String
  email     String     @unique
  phone     String?
  role      Role       @default(customer)
  status    UserStatus @default(active)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties  Property[]
  bookings    Booking[]
  assignments Assignment[] @relation("AssignedStaff")

  @@map("users")
}

model Property {
  id                 String   @id @default(cuid())
  ownerId            String
  propertyName       String
  address            String
  accessInstructions String?
  lockboxCode        String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id])
  bookings Booking[]

  @@map("properties")
}

model Checklist {
  id               String   @id @default(cuid())
  name             String
  category         String
  description      String?
  basePrice        Float
  estimatedMinutes Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items             ChecklistItem[]
  bookingChecklists BookingChecklist[]

  @@map("checklists")
}

model ChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  sectionName String?
  itemText    String
  itemType    ItemType
  required    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  checklist         Checklist          @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignmentResults AssignmentResult[]

  @@map("checklist_items")
}

model Booking {
  id            String        @id @default(cuid())
  customerId    String
  propertyId    String
  totalPrice    Float
  paymentStatus PaymentStatus @default(pending)
  status        BookingStatus @default(pending)
  scheduledDate DateTime
  backupDate    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer          User               @relation(fields: [customerId], references: [id])
  property          Property           @relation(fields: [propertyId], references: [id])
  bookingChecklists BookingChecklist[]
  assignments       Assignment[]

  @@map("bookings")
}

model BookingChecklist {
  id          String @id @default(cuid())
  bookingId   String
  checklistId String
  price       Float

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  checklist Checklist @relation(fields: [checklistId], references: [id])

  @@map("booking_checklists")
}

model Assignment {
  id                String           @id @default(cuid())
  bookingId         String
  assignedStaffId   String?
  status            AssignmentStatus @default(pending)
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  booking       Booking           @relation(fields: [bookingId], references: [id])
  assignedStaff User?             @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  results       AssignmentResult[]
  photos        AssignmentPhoto[]
  repairItems   RepairItem[]

  @@map("assignments")
}

model AssignmentResult {
  id              String   @id @default(cuid())
  assignmentId    String
  checklistItemId String
  resultValue     String
  notes           String?
  createdAt       DateTime @default(now())

  assignment    Assignment    @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem @relation(fields: [checklistItemId], references: [id])
  photos        AssignmentPhoto[]

  @@unique([assignmentId, checklistItemId])
  @@map("assignment_results")
}

model AssignmentPhoto {
  id                 String   @id @default(cuid())
  assignmentId       String
  assignmentResultId String?
  photoUrl           String
  createdAt          DateTime @default(now())

  assignment       Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  assignmentResult AssignmentResult? @relation(fields: [assignmentResultId], references: [id])

  @@map("assignment_photos")
}

model RepairItem {
  id               String       @id @default(cuid())
  assignmentId     String
  title            String
  description      String?
  estimatedHours   Float?
  hourlyRate       Float?
  materialCost     Float?
  subtotal         Float
  status           RepairStatus @default(pending)
  customerApproved Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  workOrder  WorkOrder?

  @@map("repair_items")
}

model WorkOrder {
  id             String          @id @default(cuid())
  repairItemId   String          @unique
  assignedTo     String?
  status         WorkOrderStatus @default(pending)
  scheduledDate  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  repairItem RepairItem @relation(fields: [repairItemId], references: [id])

  @@map("work_orders")
}
