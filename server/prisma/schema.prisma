generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  customer
  staff
  admin
  repair_tech
}

enum UserStatus {
  active
  inactive
  suspended
}

enum ItemType {
  pass_fail
  yes_no
  number
  text
  photo
}

enum PaymentStatus {
  pending
  paid
  refunded
  failed
}

enum OrderStatus {
  pending
  confirmed
  assigned
  in_progress
  completed
  cancelled
}

enum JobStatus {
  pending
  in_progress
  completed
  cancelled
}

enum RepairStatus {
  pending
  approved
  declined
  completed
}

enum WorkOrderStatus {
  pending
  scheduled
  in_progress
  completed
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id        String     @id @default(cuid())
  clerkId   String     @unique
  name      String
  email     String     @unique
  phone     String?
  role      Role       @default(customer)
  status    UserStatus @default(active)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  properties Property[]
  orders     Order[]
  jobs       Job[]      @relation("AssignedStaff")

  @@map("users")
}

model Property {
  id                 String   @id @default(cuid())
  ownerId            String
  propertyName       String
  address            String
  accessInstructions String?
  lockboxCode        String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  owner  User    @relation(fields: [ownerId], references: [id])
  orders Order[]

  @@map("properties")
}

model Checklist {
  id               String   @id @default(cuid())
  name             String
  category         String
  description      String?
  basePrice        Float
  estimatedMinutes Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items           ChecklistItem[]
  orderChecklists OrderChecklist[]

  @@map("checklists")
}

model ChecklistItem {
  id          String   @id @default(cuid())
  checklistId String
  sectionName String?
  itemText    String
  itemType    ItemType
  required    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  checklist  Checklist   @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  jobResults JobResult[]

  @@map("checklist_items")
}

model Order {
  id            String        @id @default(cuid())
  customerId    String
  propertyId    String
  totalPrice    Float
  paymentStatus PaymentStatus @default(pending)
  status        OrderStatus   @default(pending)
  scheduledDate DateTime
  backupDate    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  customer        User             @relation(fields: [customerId], references: [id])
  property        Property         @relation(fields: [propertyId], references: [id])
  orderChecklists OrderChecklist[]
  jobs            Job[]

  @@map("orders")
}

model OrderChecklist {
  id          String @id @default(cuid())
  orderId     String
  checklistId String
  price       Float

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  checklist Checklist @relation(fields: [checklistId], references: [id])

  @@map("order_checklists")
}

model Job {
  id              String    @id @default(cuid())
  orderId         String
  assignedStaffId String?
  status          JobStatus @default(pending)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  order        Order        @relation(fields: [orderId], references: [id])
  assignedStaff User?       @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  results      JobResult[]
  photos       JobPhoto[]
  repairItems  RepairItem[]

  @@map("jobs")
}

model JobResult {
  id              String   @id @default(cuid())
  jobId           String
  checklistItemId String
  resultValue     String
  notes           String?
  createdAt       DateTime @default(now())

  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  checklistItem ChecklistItem @relation(fields: [checklistItemId], references: [id])
  photos        JobPhoto[]

  @@unique([jobId, checklistItemId])
  @@map("job_results")
}

model JobPhoto {
  id          String   @id @default(cuid())
  jobId       String
  jobResultId String?
  photoUrl    String
  createdAt   DateTime @default(now())

  job       Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobResult JobResult? @relation(fields: [jobResultId], references: [id])

  @@map("job_photos")
}

model RepairItem {
  id               String       @id @default(cuid())
  jobId            String
  title            String
  description      String?
  estimatedHours   Float?
  hourlyRate       Float?
  materialCost     Float?
  subtotal         Float
  status           RepairStatus @default(pending)
  customerApproved Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  job       Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workOrder WorkOrder?

  @@map("repair_items")
}

model WorkOrder {
  id             String          @id @default(cuid())
  repairItemId   String          @unique
  assignedTo     String?
  status         WorkOrderStatus @default(pending)
  scheduledDate  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  repairItem RepairItem @relation(fields: [repairItemId], references: [id])

  @@map("work_orders")
}
